# Public hostname. DNS A/AAAA records must point here before first deploy.
SITE_DOMAIN=gallery.example.com

# These VITE_ values are compiled into the browser bundle. Use only the Supabase
# Project URL and Publishable key (or legacy anon key), never service_role/secret keys.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
